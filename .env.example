# ============================================
# Context Memory Framework — Configuration
# Copy this to .env and fill in your values
# ============================================

# --- LLM Provider ---
GEMINI_API_KEY=your-gemini-api-key-here

# --- Model Names (LiteLLM format) ---
PATHFINDER_MODEL=gemini/gemini-3.1-flash-lite
SUMMARIZER_MODEL=gemini/gemini-3.1-flash-lite
VERIFIER_MODEL=gemini/gemini-3.1-flash-lite
EMBEDDING_MODEL=gemini/gemini-embedding-2
# For local embeddings (zero API cost): EMBEDDING_MODEL=local/Qwen/Qwen3-Embedding-0.6B

# --- Database Connections ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
QDRANT_URL=http://localhost:6333
SQLITE_PATH=./data/memory.db

# --- Tunable Parameters ---
DEFAULT_DECAY_MODE=drift
DECAY_LAMBDA=0.01
MAX_BACKTRACK=5
CHUNK_SIZE_TOKENS=500
EDGE_WEIGHT_CEILING=5.0
BROAD_QUERY_THRESHOLD=0.6
